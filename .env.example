# ============================================================
# README-AI-Gen Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# Set at least ONE provider key for AI generation.
# ============================================================

# ── AI Provider API Keys ────────────────────────────────────
# Choose ONE or more. The tool will use the one you specify
# with --provider flag (default: openrouter).

# OpenAI: https://platform.openai.com/api-keys
# Format: sk-...
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# Format: sk-ant-...
ANTHROPIC_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
# Format: AIza...
GEMINI_API_KEY=

# OpenRouter (recommended): https://openrouter.ai/keys
# Format: sk-or-...
OPENROUTER_API_KEY=

# NVIDIA: https://build.nvidia.com/explore/discover
# Format: nvapi-...
NVIDIA_API_KEY=

# ── Optional Configuration ──────────────────────────────────

# Default provider when --provider flag is not specified
# Values: openai | anthropic | gemini | openrouter | nvidia
# DEFAULT_PROVIDER=openrouter

# Default model for the provider (provider-specific defaults used if not set)
# DEFAULT_MODEL=
